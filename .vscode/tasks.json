{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "cppbuild",
			"label": "C/C++: gcc build active file",
			"command": "gcc",
			"args": [
				"-fdiagnostics-color=always",
				"-g",
				"${file}",
				"${fileDirname}/prerequisite.c",
				"${fileDirname}/process_video.c",
				"-o",
				"${fileDirname}/${fileBasenameNoExtension}",
                "-lavformat", 
                "-lavcodec", 
                "-lavutil"
			],
			"options": {
				"cwd": "${fileDirname}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		}
	]
}