{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C/C++: gcc build and debug active file",
            "type": "cppdbg",
            "request": "launch",
            "program": "${fileDirname}/main",
            "args": ["${fileDirname}/file_example_MP4_1920_18MG.mp4"],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "targetArchitecture": "x64",
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ],
            // if debbugger doesn't stop at breakpoints or produces errors
            // this may occur due to internals temporary issues of VS Code
            // for example https://debuginfod.ubuntu.com/ doesn't respond
            // which is needed for gdb tool to work correctly in VS Code
            // in this case apply next workaround to fix problem:
            // downgrade C/C++ extension to v1.32.2
            // and add to .vscode/launch.json next snippet
            "customLaunchSetupCommands": [
                {
                    "description": "Disable debuginfod",
                    "text": "set debuginfod enabled off",
                    "ignoreFailures": true
                },
                {
                    "description": "Specify runnable file",
                    "text": "-file-exec-and-symbols /home/user/sandbox/test_task/main",
                    "ignoreFailures": true
                },
                {
                    "description": "Specify args to runnable file",
                    "text": "set args /home/user/sandbox/test_task/file_example_MP4_1920_18MG.mp4",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "C/C++: gcc build active file"
        }
    ]
}